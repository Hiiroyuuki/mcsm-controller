{
  "mcsm": {
    "instance_name1": {
      "base_url": "http://192.168.3.2:23333",
      "apikey": "replace_with_your_apikey",
      "daemon_id": "replace_with_your_daemon_id",
      "instance_uuid": "replace_with_your_instance_uuid",
      "timeout": 10,
      "chat_control_enabled": true
    },
    "instance_name2": {
      "base_url": "http://192.168.3.2:23333",
      "apikey": "replace_with_your_apikey",
      "daemon_id": "replace_with_your_daemon_id",
      "instance_uuid": "replace_with_your_instance_uuid",
      "timeout": 10,
      "chat_control_enabled": true
    }
  },
  "skill": {
    "default_instance": "instance_name1",
    "allow_instance_override": true,
    "allowed_actions": [
      "status",
      "start",
      "stop",
      "restart",
      "kill",
      "update_task",
      "send_command",
      "get_output",
      "get_messages",
      "list_instances",
      "get_instance",
      "reinstall"
    ]
  },
  "chat_control": {
    "config_instance": "pure_1_20_1",
    "trigger_word": "@openclaw",
    "poll_interval": 2,
    "output_size": 128,
    "openclaw_command": [
      "openclaw",
      "agent",
      "--local"
    ],
    "openclaw_session_args": ["--agent", "chatcontrol"],
    "openclaw_message_arg": "-m",
    "openclaw_timeout": 120,
    "response_mode": "msg",
    "response_prefix": "OpenClaw",
    "ack_message": "Received. Processing your request.",
    "error_message": "Request failed. Please try again later.",
    "log_mode": "both",
    "debug_errors_to_chat": true,
    "log_file": "chat_control.log",
    "max_reply_length": 180,
    "system_prompt": "You are OpenClaw, a Minecraft server assistant. The following content is a player request captured from in-game chat. Understand the request and handle it by using the MCSM controller skill."
  }
}
